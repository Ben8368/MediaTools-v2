#!/bin/bash
# prepare-commit-msg hook
# Automatically adds a Co-Authored-By trailer for the AI development tool
# that is driving the commit.
#
# Detection is based on environment variables that each tool injects into the
# child process it spawns to run `git` — this is reliable cross-platform
# (including Windows Git Bash, where `pgrep`/process scanning does not work).
#
# Manual override (highest priority):
#   git config mediatools.ai-tool <claude|codex|cursor|opencode>
#
# Install: run .git-hooks/install.ps1  (or copy this file to .git/hooks/)

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# --- Canonical co-author identities (GitHub-username convention) -----------
# NB: names are deliberately NOT *_COAUTHOR to avoid colliding with the
# OPENCODE_COAUTHOR env var that the legacy opencode detection checks for.
CO_CLAUDE="Co-Authored-By: claude <claude@noreply.anthropic.com>"
CO_CODEX="Co-Authored-By: codex <codex@openai.com>"
CO_CURSOR="Co-authored-by: cursoragent <cursoragent@cursor.com>"
CO_OPENCODE="Co-Authored-By: opencode <opencode@noreply.local>"

# Skip if the message already carries a Co-Authored-By trailer.
if grep -qi "Co-Authored-By:" "$COMMIT_MSG_FILE"; then
    exit 0
fi

# Skip for merge/squash commits (not authored interactively).
if [ "$COMMIT_SOURCE" = "merge" ] || [ "$COMMIT_SOURCE" = "squash" ]; then
    exit 0
fi

# Detect which AI tool is running and echo its co-author trailer.
detect_ai_tool() {
    # 1. Explicit manual override via git config.
    case "$(git config --get mediatools.ai-tool 2>/dev/null)" in
        claude|claude-code) echo "$CO_CLAUDE"; return ;;
        codex)              echo "$CO_CODEX";  return ;;
        cursor)             echo "$CO_CURSOR"; return ;;
        opencode)           echo "$CO_OPENCODE"; return ;;
    esac

    # 2. Claude Code — sets CLAUDECODE=1 plus session/entrypoint vars,
    #    and AI_AGENT=claude-code_<version>_agent.
    if [ -n "$CLAUDECODE" ] || [ -n "$CLAUDE_CODE" ] \
        || [ -n "$CLAUDE_CODE_SESSION_ID" ] || [ -n "$CLAUDE_CODE_ENTRYPOINT" ] \
        || [ "${AI_AGENT#claude-code}" != "$AI_AGENT" ]; then
        echo "$CO_CLAUDE"; return
    fi

    # 3. OpenAI Codex CLI — CODEX_SANDBOX / CODEX_CI / CODEX_THREAD_ID.
    if [ -n "$CODEX_SANDBOX" ] || [ -n "$CODEX_CI" ] || [ -n "$CODEX_THREAD_ID" ]; then
        echo "$CO_CODEX"; return
    fi

    # 4. Cursor agent — CURSOR_AGENT, or CURSOR_EXTENSION_HOST_ROLE=agent-exec.
    if [ -n "$CURSOR_AGENT" ] || [ "$CURSOR_EXTENSION_HOST_ROLE" = "agent-exec" ]; then
        echo "$CO_CURSOR"; return
    fi

    # 5. opencode — OPENCODE_CLIENT (current) or legacy session vars.
    if [ -n "$OPENCODE_CLIENT" ] || [ -n "$OPENCODE_SESSION" ] || [ -n "$OPENCODE_COAUTHOR" ]; then
        echo "$CO_OPENCODE"; return
    fi

    # No AI tool detected.
    echo ""
}

AI_COAUTHOR=$(detect_ai_tool)

if [ -n "$AI_COAUTHOR" ] && [ -s "$COMMIT_MSG_FILE" ]; then
    # Ensure the file ends with a newline (command substitution strips the
    # trailing newline, so a non-empty result means the last byte is not one).
    if [ -n "$(tail -c1 "$COMMIT_MSG_FILE")" ]; then
        printf '\n' >> "$COMMIT_MSG_FILE"
    fi
    # Blank separator line, then the trailer.
    printf '\n%s\n' "$AI_COAUTHOR" >> "$COMMIT_MSG_FILE"
fi

exit 0
